# ─────────────────────────────────────────────────────────────────────────────
# Lexsearch EvalBench — example environment file
# Copy to `.env` and edit. The DEFAULT DEMO RUNS WITH NO KEYS / NO EDITS NEEDED.
# ─────────────────────────────────────────────────────────────────────────────

# ── Answer generation backend ────────────────────────────────────────────────
# One of: mock | openai | anthropic | ollama
# Default is "mock": a fully local, deterministic extractive answerer.
LEXSEARCH_ANSWER_BACKEND=mock

# Optional API keys (only used if the matching backend is selected above)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (local LLM server) — only used if LEXSEARCH_ANSWER_BACKEND=ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Embedding model (sentence-transformers) ──────────────────────────────────
# Small, fast, downloads on first use (~80MB). Works offline after first run.
LEXSEARCH_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Cross-encoder reranker ───────────────────────────────────────────────────
# If the model cannot be downloaded, a deterministic lexical reranker is used.
LEXSEARCH_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Retrieval defaults ───────────────────────────────────────────────────────
LEXSEARCH_CHUNK_SIZE=550
LEXSEARCH_CHUNK_OVERLAP=80
LEXSEARCH_HYBRID_WEIGHT=0.5
LEXSEARCH_TOP_K=10
LEXSEARCH_FUSION=rrf

# ── Storage ──────────────────────────────────────────────────────────────────
LEXSEARCH_DB_PATH=data/lexsearch.db
LEXSEARCH_INDEX_DIR=data/index

# ── Offline mode ─────────────────────────────────────────────────────────────
# Set to 1 to force fully offline behaviour (hashing embeddings + lexical rerank)
# Useful for CI or no-network demos.
LEXSEARCH_OFFLINE=0
